{
  "name": "sneaks-community-website",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tsx --env-file=.env src/index.ts",
    "build": "npm run build:lib && npm run build:css && npm run build:js",
    "build:lib": "mkdir -p public/lib && cp node_modules/motion/dist/motion.js public/lib/motion.js && cp node_modules/lucide/dist/umd/lucide.js public/lib/lucide.js",
    "build:css": "npx @tailwindcss/cli -i ./src/input.css -o ./public/tailwind.css --minify",
    "build:js": "esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --minify --outdir=dist",
    "start": "node --env-file=.env dist/index.js",
    "clean": "rm -rf dist && rm -f public/tailwind.css && rm -f public/lib/*.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "express": "^4.21.2",
    "express-rate-limit": "^8.4.1",
    "gamedig": "^5.3.2",
    "helmet": "^8.1.0",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/gamedig": "^5.0.3",
    "@types/node": "^24.12.2",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.5.0",
    "lucide": "^1.11.0",
    "motion": "^12.38.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.59.0"
  },
  "overrides": {
    "fast-xml-parser": "^5.5.12"
  }
}
